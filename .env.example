# Zkopíruj tento soubor jako `.env` a vyplň hodnoty.
# Supabase: https://supabase.com/dashboard → projekt → Settings → API
#
# Pozn.: Proměnné začínající NEXT_PUBLIC_ se při `docker compose build` vloží do frontendu.
# Po změně URL nebo klíčů znovu sestav image: docker compose build --no-cache

# Povinné — URL projektu (Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Použij jeden z následujících veřejných klíčů (anon nebo nový publishable — podle dashboardu):
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Volitelné alternativy k anon klíči (stačí vyplnit jednu variantu):
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Volitelné — vlastní port na hostiteli (výchozí 3000). V docker-compose.yml: ports: "${HUT_PORT:-3000}:3000"
# HUT_PORT=3000
